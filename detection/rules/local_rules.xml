<group name="ics,scada,ot-security">

  <!-- Base rule: match ICS_EVENT as program name -->
  <rule id="100001" level="3">
    <program_name>ICS_EVENT</program_name>
    <description>ICS/SCADA event received from TANGEDCO OT network</description>
    <group>ics_event</group>
  </rule>

  <!-- T0855: Unauthorized Command -->
  <rule id="100002" level="12">
    <if_sid>100001</if_sid>
    <match>T0855_UNAUTHORIZED_COMMAND</match>
    <description>MITRE T0855: Unauthorized Modbus command - pump control override detected</description>
    <mitre>
      <id>T0855</id>
    </mitre>
    <group>ics_attack,unauthorized_command</group>
  </rule>

  <!-- T0856: Spoof Reporting -->
  <rule id="100003" level="14">
    <if_sid>100001</if_sid>
    <match>T0856_SPOOF_REPORTING</match>
    <description>MITRE T0856: Spoofed sensor reporting detected</description>
    <mitre>
      <id>T0856</id>
    </mitre>
    <group>ics_attack,spoof_reporting</group>
  </rule>

  <!-- T0814: Denial of Control -->
  <rule id="100004" level="15">
    <if_sid>100001</if_sid>
    <match>T0814_DENIAL_OF_CONTROL</match>
    <description>MITRE T0814: Denial of control - critical infrastructure impact</description>
    <mitre>
      <id>T0814</id>
    </mitre>
    <group>ics_attack,denial_of_control</group>
  </rule>

</group>
